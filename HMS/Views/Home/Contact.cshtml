@model HMS.Models.Contact
@{
    ViewData["Title"] = "Contact us";
}

<div class="row g-4">
    <div class="col-12 col-lg-7">
        <h2 class="mb-3">Contact Form</h2>

        @if (TempData["ContactSuccess"] != null)
        {
            <div class="alert alert-success" role="alert">
                @TempData["ContactSuccess"]
            </div>
        }

        <form asp-action="Contact" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter your name" required />
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" required />
            </div>

            <div class="mb-3">
                <label asp-for="Message" class="form-label">Message</label>
                <textarea asp-for="Message" rows="4" class="form-control" placeholder="Write your message" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
    </div>

    <div class="col-12 col-lg-5">
        <h3 class="mb-3">Contact Information</h3>
        <div class="card shadow-sm">
            <div class="card-body">
                <p class="mb-2"><strong>Phone:</strong> +250 700 000 000</p>
                <p class="mb-2"><strong>Email:</strong> support@hms.rw</p>
                <p class="mb-2"><strong>Address:</strong> Kigali, Rwanda</p>
                <p class="mb-0"><strong>Working Hours:</strong> Mon - Fri, 8:00 AM - 5:00 PM</p>
            </div>
        </div>
    </div>
</div>
